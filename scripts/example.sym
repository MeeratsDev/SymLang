$year = i(input("Enter the last olymics year: "));
$curYear = i(2026);
$year += 4;
print($year);

? ($year != $curYear + 4) {
    ? ($year < $curYear) {
        print("HOW DID YOU GO TO THE PAST!?!?!?");
    } ~ {
        $diff = $year - $curYear;
        $diff = s($diff);
        print("The year is " + $diff + " years after the current year.");
    }
}
